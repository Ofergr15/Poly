# Copy this to .env and fill in your values

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated list of allowed Google email addresses (leave empty to allow any Google account)
ALLOWED_EMAILS=grosfeldofer@gmail.com

# Simulation API base URL (where run_week1_simulation.py is running)
SIMULATION_API=http://localhost:8889

# Public URL of this app (used for OAuth callback, e.g. https://yourdomain.com or ngrok URL)
# Leave empty for local development (will use http://localhost:8080)
PUBLIC_URL=
